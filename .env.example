# Copy this file to .env and fill in your values
# Never commit .env

# Supabase project settings (Settings → API in the Supabase dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Storage
STORAGE_MODE=local        # "local" or "s3"
S3_BUCKET=                # your S3 bucket name (S3 mode only)

# AWS credentials (S3 mode only — use IAM role on App Runner instead of keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2
